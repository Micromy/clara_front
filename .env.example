# Copy this file to .env and fill in the values. .env is gitignored.

# ── Frontend (Vite) ─────────────────────────────────────────────
# Set to "true" to bypass the internal API and serve everything
# from public/data/*.json (useful when the DB is unreachable).
# Leave unset / "false" for production builds.
VITE_USE_LOCAL_DATA=false

# ── Backend (scripts/db_to_json.py) ─────────────────────────────
DB_USER=
DB_PASSWORD=
DB_DSN=(DESCRIPTION=(LOAD_BALANCE=...)(CONNECT_DATA=(SERVICE_NAME=...)))

# Optional: path to Oracle Instant Client. Leave blank to rely on
# ORACLE_HOME / LD_LIBRARY_PATH being set system-wide.
ORACLE_CLIENT_LIB=
